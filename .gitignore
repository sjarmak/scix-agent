data/*
# ...except small, checked-in evaluation artifacts that track with code.
# Do NOT put credentials / env dumps under data/eval/*.csv|yaml — this
# carve-out has no way to distinguish calibration data from secrets.
!data/eval/
data/eval/*
!data/eval/*.csv
!data/eval/*.yaml
!data/eval/*.md
!data/eval/*.jsonl
!data/eval/.gitkeep

