# deploy/.env — copy to .env and fill in. Never commit the real .env.

# Bearer token required for every MCP request. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=REPLACE_WITH_A_32+_BYTE_RANDOM_TOKEN

# Postgres DSN. Use the read-only role, not the superuser.
# host.docker.internal resolves to the docker host's gateway IP.
SCIX_DSN="host=host.docker.internal dbname=scix user=scix_reader password=scix_reader_local_only"

# Host path to the HuggingFace cache. INDUS model weights live here.
# On this machine it's usually ~/.cache/huggingface (absolute path required).
HF_CACHE_DIR=/home/ds/.cache/huggingface

# Cloudflare named-tunnel token. To get one:
#   1. Sign up at https://dash.cloudflare.com/ (free).
#   2. Zero Trust → Networks → Tunnels → Create a tunnel (named "scix-mcp").
#   3. Choose "Cloudflared" connector and copy the token shown.
#   4. Under "Public Hostnames", point your chosen subdomain at
#      http://scix-mcp:8000 (container DNS name, NOT localhost).
# The token is a single opaque string you paste here.
CF_TUNNEL_TOKEN=REPLACE_WITH_CLOUDFLARE_TUNNEL_TOKEN
