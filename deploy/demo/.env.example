# Copy to .env on the VPS and fill in real values. chmod 600 .env
# All of these are required by docker-compose.yml.

# Bearer token for Authorization: Bearer <token> on /mcp/ requests.
# Generate: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
MCP_AUTH_TOKEN=

# Postgres password for the internal compose network. Not exposed outside
# the compose network, but still use a random value.
# Generate: python3 -c 'import secrets; print(secrets.token_urlsafe(24))'
POSTGRES_PASSWORD=

# Cloudflare named-tunnel token (dashboard: Zero Trust -> Networks ->
# Tunnels -> your tunnel -> Install connector -> "docker" tab).
CF_TUNNEL_TOKEN=

# Host path to the HuggingFace cache that contains INDUS + tokenizer.
# On the VPS, rsync your laptop's ~/.cache/huggingface (just the
# nasa-impact/nasa-smd-ibm-st-v2 snapshot) to e.g. /opt/scix-demo/hf-cache
# and point here.
HF_CACHE_DIR=/opt/scix-demo/hf-cache
